# Copy this file to config.env and fill in your real values.
# config.env is .gitignore'd and will never be committed.

# Gmail address the RPi sends FROM (can be the same as RECIPIENT_EMAIL)
GMAIL_SENDER=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# How to create one:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (must be ON)
#   2. Search for "App passwords" in the search bar
#   3. Select "Mail" + "Other (custom name)" → name it "RPi Solar Station"
#   4. Copy the 16-character password here (no spaces)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address that receives the weekly report
RECIPIENT_EMAIL=your_email@gmail.com
